# =============================================================================
# .env -- Kolla Meeting
# =============================================================================
# NEVER commit this file to version control.
# =============================================================================

# CLOUDFLARE TUNNEL
# Leave empty for Quick Tunnel. Set token for Named Tunnel.
CLOUDFLARE_TUNNEL_TOKEN=

# Auto-updated by scripts/start.ps1 on each run
VITE_API_BASE_URL=https://developmental-newton-intent-only.trycloudflare.com/api/v1
VITE_WS_URL=wss://developmental-newton-intent-only.trycloudflare.com/ws
# Wildcard: Cloudflare tunnel URL changes on every restart — JWT validates auth
CORS_ALLOWED_ORIGINS=https://developmental-newton-intent-only.trycloudflare.com

# MYSQL DATABASE
MYSQL_ROOT_PASSWORD=kollaroot
MYSQL_DATABASE=kolla_meeting
MYSQL_USER=kolla
MYSQL_PASSWORD=kollapass

# BACKEND -- Spring Boot 3.2
JWT_SECRET=aTJXTVo1RG1ROWwxbkx4T0FYVkt1Z0YzYU5lSnJmcFB6YkVDcVNUMA==
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=
JITSI_SERVER_URL=https://meet.jit.si
JITSI_APP_ID=kolla
JITSI_APP_SECRET=jitsi-secret-change-me
GIPFORMER_CALLBACK_API_KEY=ryw6m7LaunlDhRJHF5fUIQdY0WTVSxEApBtcZCzX4Ne9i2G3

# FRONTEND -- React 18 + Vite
VITE_JITSI_URL=https://meet.jit.si

# GIPFORMER -- cuda = GPU, cpu = CPU-only fallback
DEVICE=cuda

# JAAS INTEGRATION -- Jitsi as a Service (8x8.vc)
