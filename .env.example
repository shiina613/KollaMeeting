# =============================================================================
# .env.example — Kolla Meeting Rebuild
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
#
#   cp .env.example .env
#
# NEVER commit .env to version control — it contains secrets.
# All variables with a default value in docker-compose.yml are marked [default].
# Variables marked [REQUIRED] have no safe default and MUST be set.
# =============================================================================


# =============================================================================
# CLOUDFLARE TUNNEL
# =============================================================================
# Kolla dùng Cloudflare Tunnel để expose dịch vụ ra internet mà không cần
# mở inbound port, IP tĩnh, hay quản lý SSL certificate thủ công.
#
# Quick Tunnel (mặc định): không cần cấu hình gì thêm.
#   - URL dạng https://xxx-yyy-zzz.trycloudflare.com được sinh tự động mỗi lần khởi động.
#   - Chạy: .\scripts\start.ps1 (Windows) hoặc ./scripts/start.sh (WSL2)
#     để tự động cập nhật URL vào .env và rebuild frontend.
#
# Named Tunnel (khi có domain cố định):
#   - Tạo tunnel trên Cloudflare Zero Trust dashboard, lấy tunnel token.
#   - Set CLOUDFLARE_TUNNEL_TOKEN bên dưới.
#   - Không cần thay đổi kiến trúc — script vẫn hoạt động như cũ.
#
# [optional — để trống cho Quick Tunnel mode]
CLOUDFLARE_TUNNEL_TOKEN=

# Tunnel URL hiện tại (được startup script tự động cập nhật sau mỗi lần khởi động).
# Thay <cloudflare-domain> bằng domain thực nếu dùng Named Tunnel.
# [auto-updated by scripts/start.ps1 or scripts/start.sh]
VITE_API_BASE_URL=https://<cloudflare-domain>/api/v1
VITE_WS_URL=wss://<cloudflare-domain>/ws
CORS_ALLOWED_ORIGINS=https://<cloudflare-domain>


# =============================================================================
# MYSQL DATABASE
# =============================================================================

# Root password for the MySQL container.
# [REQUIRED — change from default before deploying]
MYSQL_ROOT_PASSWORD=kollaroot

# Application database name.
# [default: kolla_meeting]
MYSQL_DATABASE=kolla_meeting

# Application database user.
# [default: kolla]
MYSQL_USER=kolla

# Application database password.
# [REQUIRED — change from default before deploying]
MYSQL_PASSWORD=kollapass


# =============================================================================
# BACKEND — Spring Boot 3.2
# =============================================================================

# JWT signing secret. Must be a valid Base64-encoded string of at least 32 bytes (256 bits).
# Generate a strong secret: openssl rand -base64 32
# [REQUIRED]
JWT_SECRET=Y2hhbmdlbWUtc3VwZXItc2VjcmV0LWtleS1hdC1sZWFzdC0zMi1jaGFycw==

# JWT access token expiry in milliseconds.
# [default: 86400000 = 24 hours]
JWT_EXPIRATION_MS=86400000

# JWT refresh token expiry in milliseconds.
# [default: 604800000 = 7 days]
JWT_REFRESH_EXPIRATION_MS=604800000

# Spring datasource URL (auto-constructed from MySQL vars in docker-compose).
# Override only if you are connecting to an external MySQL instance.
# [default: constructed from MYSQL_* vars above]
# SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/kolla_meeting?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Ho_Chi_Minh

# Redis host and port (override if using an external Redis instance).
# [default: redis / 6379 — the redis service in docker-compose]
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379

# Redis password (leave empty if Redis has no auth).
# [default: empty]
SPRING_REDIS_PASSWORD=

# Jitsi server URL as seen by the backend (for JWT token generation).
# Jitsi self-hosted đã được thay bằng Jitsi public vì Cloudflare Tunnel
# không hỗ trợ UDP/WebRTC (JVB port 10000).
# [default: https://meet.jit.si]
JITSI_SERVER_URL=https://meet.jit.si

# Jitsi app ID and shared secret for authenticated rooms (Prosody JWT auth).
# Must match the values configured in your Jitsi Prosody config.
# [REQUIRED if ENABLE_AUTH=1]
JITSI_APP_ID=kolla
JITSI_APP_SECRET=jitsi-secret-change-me

# Internal API key used by the ASR service to authenticate transcription callbacks.
# Generate: openssl rand -hex 24
# [REQUIRED]
ASR_CALLBACK_API_KEY=internal-callback-key-change-me
# Deprecated alias (docker-compose vẫn đọc nếu ASR_CALLBACK_API_KEY chưa set):
# GIPFORMER_CALLBACK_API_KEY=internal-callback-key-change-me

# =============================================================================
# DIGITAL SIGNATURE — Ký số biên bản PDF (chủ tọa xác nhận)
# =============================================================================
# Bật ký số PKCS#7 khi chủ tọa POST /minutes/confirm.
# Cần file PKCS#12 (.p12/.pfx) hoặc JKS chứa chứng thư số + khóa bí mật (từ CA hoặc tự ký để thử).
# Hướng dẫn: docs/digital-signature.md
#
# [REQUIRED để xác nhận biên bản — nếu false, API confirm trả lỗi cấu hình]
DIGITAL_SIGNATURE_ENABLED=false
DIGITAL_SIGNATURE_KEYSTORE_PATH=/app/secrets/signing.p12
DIGITAL_SIGNATURE_KEYSTORE_PASSWORD=change-me
DIGITAL_SIGNATURE_KEYSTORE_TYPE=PKCS12
# Để trống = alias khóa đầu tiên trong keystore
DIGITAL_SIGNATURE_KEY_ALIAS=
DIGITAL_SIGNATURE_REASON=Xác nhận biên bản cuộc họp
DIGITAL_SIGNATURE_LOCATION=KollaMeeting


# =============================================================================
# FRONTEND — React 18 + Vite
# =============================================================================

# Jitsi server URL as seen from the browser (used to load external_api.js).
# Trỏ đến Jitsi public — không cần self-host.
# [default: https://meet.jit.si]
VITE_JITSI_URL=https://meet.jit.si


# =============================================================================
# ASR SERVICE — Python FastAPI (phiên âm tiếng Việt, port 8000)
# =============================================================================

# ASR engine (ASR_BACKEND):
#   phowhisper — PhoWhisper-medium CT2 int8_float16 (VI + code-switching, khuyến nghị)
#   gipformer  — Gipformer-65M-RNNT ONNX (tiếng Việt thuần, backend tùy chọn)
#   whisper    — alias của phowhisper (tương thích cấu hình cũ)
# [default in docker-compose: phowhisper]
ASR_BACKEND=phowhisper

# Đường dẫn thư mục mô hình CTranslate2 (chứa model.bin), tương đối asr-service/ hoặc tuyệt đối.
PHOWHISPER_MODEL_PATH=models/phowhisper-medium-ct2-int8_float16
PHOWHISPER_LANGUAGE=vi

# Inference device.
#   cuda  — GPU inference via NVIDIA CUDA (requires nvidia-container-toolkit)
#   cpu   — CPU-only ONNX inference (automatic fallback, no GPU needed)
# [default: cuda]
DEVICE=cuda

# Redis URL for the transcription job queue.
# [default: redis://redis:6379]
# REDIS_URL=redis://redis:6379

# Spring Boot callback URL for the ASR service to POST transcription results.
# [default: http://backend:8080/api/v1/transcription/callback]
# BACKEND_CALLBACK_URL=http://backend:8080/api/v1/transcription/callback


# =============================================================================
# JAAS INTEGRATION — Jitsi as a Service (8x8.vc)
# =============================================================================
# JaaS thay thế meet.jit.si để loại bỏ giới hạn 5 phút và yêu cầu đăng nhập
# Google/GitHub. Free tier: 25 MAU/tháng, không giới hạn thời gian.
#
# Để lấy thông tin cấu hình:
#   1. Đăng ký tại https://jaas.8x8.vc
#   2. Tạo một API Key trong JaaS console → lấy AppID, Key ID, và Private Key.
#
# Khi JAAS_APP_ID để trống, hệ thống tự động fallback về meet.jit.si
# (không cần JWT, không breaking change).
# =============================================================================

# AppID của ứng dụng JaaS, lấy từ JaaS console (8x8.vc).
# Ví dụ: vpaas-magic-cookie-abc123
# [REQUIRED for JaaS — leave empty to use meet.jit.si fallback]
JAAS_APP_ID=

# Full API Key ID, format: vpaas-magic-cookie-{AppID}/{keyId}
# Lấy từ JaaS console khi tạo API Key.
# Ví dụ: vpaas-magic-cookie-abc123/abcd1234
# [REQUIRED for JaaS — leave empty to use meet.jit.si fallback]
JAAS_API_KEY=

# RSA private key (PEM format, PKCS#8) dùng để ký JWT token.
# Lấy từ JaaS console khi tạo API Key.
# Thay tất cả newline trong file PEM bằng ký tự \n trước khi paste vào đây.
# Ví dụ: -----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkq...\n-----END PRIVATE KEY-----
# [REQUIRED for JaaS — leave empty to use meet.jit.si fallback]
JAAS_PRIVATE_KEY=

# AppID dùng ở phía frontend (React/Vite) để xác định domain và format room name.
# Phải trùng với giá trị JAAS_APP_ID ở trên.
# Khi được set, frontend dùng domain 8x8.vc và room name format {VITE_JAAS_APP_ID}/{meetingCode}.
# Khi để trống, frontend fallback về VITE_JITSI_URL và plain meetingCode.
# [REQUIRED for JaaS — must match JAAS_APP_ID]
VITE_JAAS_APP_ID=
