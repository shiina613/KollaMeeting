# =============================================================================
# .env.example — Kolla Meeting Rebuild
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
#
#   cp .env.example .env
#
# NEVER commit .env to version control — it contains secrets.
# All variables with a default value in docker-compose.yml are marked [default].
# Variables marked [REQUIRED] have no safe default and MUST be set.
# =============================================================================


# =============================================================================
# DOMAIN & SSL (Nginx + Certbot)
# =============================================================================

# Your public domain name. Used by Nginx for virtual hosts and SSL certs.
# Nginx will serve:
#   https://${DOMAIN}        → frontend
#   https://${DOMAIN}/api    → backend
#   https://meet.${DOMAIN}   → Jitsi
# [REQUIRED]
DOMAIN=kolla.example.com

# DuckDNS token for dynamic DNS updates (if using DuckDNS for your domain).
# Obtain from https://www.duckdns.org/
# [REQUIRED if using DuckDNS]
DUCKDNS_TOKEN=your-duckdns-token-here

# DuckDNS subdomain (the part before .duckdns.org), e.g. "kolla"
# [REQUIRED if using DuckDNS]
DUCKDNS_SUBDOMAIN=kolla

# Email address for Let's Encrypt certificate registration and renewal notices.
# [REQUIRED for production SSL]
CERTBOT_EMAIL=admin@example.com


# =============================================================================
# MYSQL DATABASE
# =============================================================================

# Root password for the MySQL container.
# [REQUIRED — change from default before deploying]
MYSQL_ROOT_PASSWORD=kollaroot

# Application database name.
# [default: kolla_meeting]
MYSQL_DATABASE=kolla_meeting

# Application database user.
# [default: kolla]
MYSQL_USER=kolla

# Application database password.
# [REQUIRED — change from default before deploying]
MYSQL_PASSWORD=kollapass


# =============================================================================
# BACKEND — Spring Boot 3.2
# =============================================================================

# JWT signing secret. Must be at least 32 characters.
# Generate a strong secret: openssl rand -hex 32
# [REQUIRED]
JWT_SECRET=changeme-super-secret-key-at-least-32-chars

# JWT access token expiry in milliseconds.
# [default: 86400000 = 24 hours]
JWT_EXPIRATION_MS=86400000

# JWT refresh token expiry in milliseconds.
# [default: 604800000 = 7 days]
JWT_REFRESH_EXPIRATION_MS=604800000

# Spring datasource URL (auto-constructed from MySQL vars in docker-compose).
# Override only if you are connecting to an external MySQL instance.
# [default: constructed from MYSQL_* vars above]
# SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/kolla_meeting?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Ho_Chi_Minh

# Redis host and port (override if using an external Redis instance).
# [default: redis / 6379 — the redis service in docker-compose]
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379

# Redis password (leave empty if Redis has no auth).
# [default: empty]
SPRING_REDIS_PASSWORD=

# Jitsi server URL as seen by the backend (for JWT token generation).
# [default: https://jitsi.kolla.local:8443]
JITSI_SERVER_URL=https://meet.kolla.example.com

# Jitsi app ID and shared secret for authenticated rooms (Prosody JWT auth).
# Must match the values configured in your Jitsi Prosody config.
# [REQUIRED if ENABLE_AUTH=1]
JITSI_APP_ID=kolla
JITSI_APP_SECRET=jitsi-secret-change-me

# Internal API key used by Gipformer to authenticate transcription callbacks.
# Generate: openssl rand -hex 24
# [REQUIRED]
GIPFORMER_CALLBACK_API_KEY=internal-callback-key-change-me


# =============================================================================
# FRONTEND — React 18 + Vite
# =============================================================================

# Backend API base URL as seen from the browser.
# In production this is the Nginx-proxied path.
# [default: http://localhost:8080/api/v1]
VITE_API_BASE_URL=https://kolla.example.com/api/v1

# Jitsi server URL as seen from the browser (used to load external_api.js).
# [default: https://jitsi.kolla.local:8443]
VITE_JITSI_URL=https://meet.kolla.example.com


# =============================================================================
# GIPFORMER — Python FastAPI + sherpa-onnx
# =============================================================================

# Inference device.
#   cuda  — GPU inference via NVIDIA CUDA (requires nvidia-container-toolkit)
#   cpu   — CPU-only ONNX inference (automatic fallback, no GPU needed)
# [default: cuda]
DEVICE=cuda

# Redis URL for the transcription job queue.
# [default: redis://redis:6379]
# REDIS_URL=redis://redis:6379

# Spring Boot callback URL for Gipformer to POST transcription results.
# [default: http://backend:8080/api/v1/transcription/callback]
# BACKEND_CALLBACK_URL=http://backend:8080/api/v1/transcription/callback


# =============================================================================
# JITSI MEET (self-hosted)
# =============================================================================

# Public URL of the Jitsi instance (used by Jitsi web container).
# [default: https://jitsi.kolla.local:8443]
JITSI_PUBLIC_URL=https://meet.kolla.example.com

# XMPP domain settings (change only if you customise Prosody config).
# [defaults shown]
XMPP_DOMAIN=meet.jitsi
XMPP_AUTH_DOMAIN=auth.meet.jitsi
XMPP_MUC_DOMAIN=muc.meet.jitsi
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi

# Public IP(s) that the Jitsi Videobridge (JVB) advertises to clients.
# Set to your server's public IP address.
# [REQUIRED for external participants]
JVB_ADVERTISE_IPS=127.0.0.1

# Enable Jitsi JWT authentication (0 = disabled, 1 = enabled).
# Set to 1 and configure JITSI_APP_ID / JITSI_APP_SECRET for authenticated rooms.
# [default: 0]
JITSI_ENABLE_AUTH=0

# Allow unauthenticated guests to join (only relevant when ENABLE_AUTH=1).
# [default: 1]
JITSI_ENABLE_GUESTS=1
